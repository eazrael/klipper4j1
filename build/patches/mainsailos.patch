@@ -0,0 +1,223 @@
+#!/bin/bash
+# Generations of developers used file hierarchies instead of "yaml archives"
+set -e
+
+TARGET_NAME=${1:-"snapmakerj1"}
+IMAGE_TYPE=${2:-armbian}
+SPECIAL_MODULES=${3:-"50-kiauh"}
+
+START_TIME=$(date +'%Y%m%d_%H%M%S')
+WORKDIR=build_${TARGET_NAME}_${START_TIME}
+
+if [ -e "${WORKDIR}" ]; then 
+    echo Workdir "'${WORKDIR}'" already exists 1>&2
+    exit 1
+fi 
+
+mkdir -p "${WORKDIR}"
+
+#Unpack image 
+echo "🛠 Unpack and rename image"
+
+# search for the image file in the build directory
+IMG_FILE=$(ls -t *.img *.img.xz 2>/dev/null | head -n 1)
+
+if [[ "$IMG_FILE" == *.img.xz ]]; then
+    echo "Found compressed Image file: ${IMG_FILE}"
+
+    # extract the image file
+    xzcat -T0 "${IMG_FILE}" > "${WORKDIR}/input.img"
+elif [[ "$IMG_FILE" == *.img ]]; then
+    echo "Found uncompressed image file: ${IMG_FILE}"
+    ln "${IMG_FILE}" "${WORKDIR}/input.img"
+else
+    echo "No images found... " 1>&2
+    exit 1
+fi
+
+# remove disabled
+function remove_disabled
+{
+    local path=${1}
+
+    if [ ! -d "${path}" ]
+    then 
+        echo Path "'${path}'" is not a directory 1>&2
+        exit 1
+    fi
+
+    for file in "${path}"/*.disabled
+    do     
+        if [ -e "${file}" ]
+        then 
+            module=${path}/$(basename "${file}" .disabled)
+            rm -f "${module}"
+            rm -f "${file}"
+        fi
+    done 
+}
+
+function patch_append
+{
+    local targetpath=${1}
+    
+    for appendfile in "${targetpath}"/*.append
+    do 
+        if [ -f "${appendfile}" ]
+        then 
+            module=${targetpath}/$(basename "${appendfile}" .append)
+            if [ -f "${module}" ]
+            then
+                cat "${appendfile}" >> "${module}"
+            fi
+            rm "${appendfile}"
+        fi
+    done 
+}
+
+function copy_files
+{
+    local source_path=${1}
+    local target_path=${2}
+
+    if [ ! -d "${source_path}" ]
+    then 
+        return 0
+    fi
+
+    if [ ! -e "$target_path" ]
+    then 
+        mkdir -p "${target_path}"
+    fi
+
+    for file in "${source_path}"/*
+    do
+        if [ -f "${file}" ]
+        then 
+            target_file=${target_path}/$(basename "${file}")
+            cp "${file}" "${target_file}"
+        fi
+    done
+}
+
+function copy_files_recursive
+{
+    local source_path=${1}
+    local target_path=${2}
+
+    if [ ! -d "${source_path}" ]
+    then 
+        return 0
+    fi
+
+    if [ ! -e "$target_path" ]
+    then 
+        mkdir -p "${target_path}"
+    fi
+
+    for file in "${source_path}"/*
+    do
+        if [ -e "${file}" ]
+        then 
+            target_file=${target_path}/$(basename "${file}")
+            cp -r "${file}" "${target_file}"
+        fi
+    done
+}
+
+# Copy generic scripts 
+echo "📋 Copy generic and type scripts"
+
+copy_files "modules/generic" "${WORKDIR}/scripts"
+copy_files_recursive "modules/generic/files" "${WORKDIR}/scripts/files"
+#TODO: this recursive
+remove_disabled "${WORKDIR}/scripts"
+remove_disabled "${WORKDIR}/scripts/files"
+patch_append "${WORKDIR}/scripts"
+patch_append "${WORKDIR}/scripts/files"
+
+# copy distro files 
+copy_files "modules/${IMAGE_TYPE}" "${WORKDIR}/scripts/"
+copy_files_recursive "modules/${IMAGE_TYPE}/files" "${WORKDIR}/scripts/files"
+remove_disabled "${WORKDIR}/scripts/"
+remove_disabled "${WORKDIR}/scripts/files"
+patch_append "${WORKDIR}/scripts"
+patch_append "${WORKDIR}/scripts/files"
+
+echo "📋 Copy special modules"
+# YAML.. JSON 
+# why via temp dir??
+echo "Special modules found for ${TARGET_NAME}: ${SPECIAL_MODULES}"
+
+# copy additional files for special modules
+if [ -d "modules/special/files" ]; then
+    echo "Copying common special files..."
+    cp -r modules/special/files/* "${WORKDIR}/scripts/files/"
+fi
+
+for module in "${SPECIAL_MODULES[@]}"
+do 
+    echo "Copying module: ${module}"
+    cp "modules/special/${module}" "${WORKDIR}/scripts/"
+done 
+
+remove_disabled "${WORKDIR}"/scripts
+remove_disabled "${WORKDIR}"/scripts/files
+patch_append "${WORKDIR}/scripts"
+patch_append "${WORKDIR}/scripts/files"
+
+
+copy_files "configs/${TARGET_NAME}/scripts" "${WORKDIR}/scripts/"
+copy_files_recursive "configs/${TARGET_NAME}/scripts/files" "${WORKDIR}/scripts/files"
+remove_disabled "${WORKDIR}/scripts/"
+remove_disabled "${WORKDIR}/scripts/files"
+patch_append "${WORKDIR}/scripts"
+patch_append "${WORKDIR}/scripts/files"
+
+
+echo "📇 Generate config.local"
+if [ -f "configs/${TARGET_NAME}/config.local" ]; then 
+    cp "configs/${TARGET_NAME}/config.local" "${WORKDIR}/config.local"
+else 
+    touch "${WORKDIR}/config.local"
+fi
+
+#EDITBASE_ seems not to be used
+# print("Generating config.local file...")
+# import os, json
+# env_vars = json.loads(os.environ.get("MATRIX_ENV", "{}"))
+# with open("config.local", "w") as f:
+#     for key, value in env_vars.items():
+#         if not key.startswith("EDITBASE_"):
+#             key = "EDITBASE_" + key
+#         f.write(f"{key}={value}\n")
+
+echo "🔎 Show scripts"
+ls -al "${WORKDIR}/scripts"
+
+echo "🏗 Run CustoPiZer"
+
+# if [ -d "./build" ]; then 
+#     rm -rf build
+# fi 
+# mkdir build
+cd "${WORKDIR}"
+docker run --rm \
+    --user 0:0 \
+    --cap-add setuid --cap-add=SYS_PTRACE --privileged  --security-opt seccomp=unconfined --security-opt apparmor=unconfined \
+    -v "${PWD}":/CustoPiZer/workspace \
+    -v "${PWD}/config.local":/CustoPiZer/config.local:ro \
+    custopizer:evil
+#     ghcr.io/octoprint/custopizer:main
+
+# TODO
+exit 0
+
+echo "✏ Rename image"
+IMAGE_NAME="MainsailOS-${IMAGE_TYPE}_${TARGET_NAME}_${START_DATE}.img
+mv output.img "${IMAGE_NAME}"
+
+echo "🛠 Compressing Image"
+echo "🔐 Create hash"
+
+
